# Stock Brain — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# This file is committed and acts as the canonical variable reference.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only. Never expose in frontend code or logs.
SUPABASE_SERVICE_ROLE_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Anthropic AI ──────────────────────────────────────────────────────────────
# Used by /reports/ai-strategy to generate strategic recommendations.
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Pre-auth development fallback ─────────────────────────────────────────────
# Used as created_by actor until Phase 3 (Supabase Auth) is implemented.
# Any valid UUID works — it does not need to exist in the users table while
# the FK constraint is dropped (migration 007). Remove once auth is live.
DEV_ACTOR_ID=00000000-0000-0000-0000-000000000001
